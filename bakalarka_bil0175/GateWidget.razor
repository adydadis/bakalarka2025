@using Blazor.Diagrams.Components.Renderers
@using bakalarka_bil0175
@using Blazor.Diagrams.Core.Models
@using Blazor.Diagrams

<div class="gate-container"
     style="position: relative;
         background: white;
         padding: 5px;
         min-width: 80px;
         text-align: center;
         z-index: @(Node.IsNegatedVersion ? "1" : "10");
     border: 2px solid @(Node.IsNegatedVersion ? "#dc3545" : "#007bff");
     border-radius: @(Node.IsNegatedVersion ? "0px" : "8px");">

    @* Porty *@
    <div style="position: absolute; top: -10px; left: 0; right: 0; display: flex; justify-content: center; gap: 10px;">
        @foreach (var port in Node.Ports.Where(p => p.Alignment == PortAlignment.Top))
        {
            <PortRenderer Port="port">
                <div style="width: 12px; height: 12px; background: #555; border-radius: 50%; border: 2px solid white; cursor: crosshair;"></div>
            </PortRenderer>
        }
    </div>

    @* Hradla *@
    <div style="margin-top: 5px;">
        <strong style="font-size: 1em; color: @(Node.IsNegatedVersion ? "#dc3545" : "#007bff");">
            @Node.Label
        </strong>
    </div>

    @* Status *@
    <div style="font-size: 1.2em; font-weight: bold; border-top: 1px solid #eee;">
        @(Node.Status == NodeState.True ? "1" : "0")
    </div>

    @* Porty *@
    <div style="position: absolute; bottom: -10px; left: 0; right: 0; display: flex; justify-content: center; gap: 15px;">
        @foreach (var port in Node.Ports.Where(p => p.Alignment == PortAlignment.Bottom))
        {
            <PortRenderer Port="port">
                <div style="width: 12px; height: 12px; background: #555; border-radius: 50%; border: 2px solid white; cursor: crosshair;"></div>
            </PortRenderer>
        }
    </div>



    @* SMAZAT *@
    <button @onclick="Delete" @onclick:stopPropagation="true"
            style="position: absolute; top: -8px; right: -8px; background: #dc3545; color: white; border:1px solid #a71d2a; width: 20px; height: 20px; font-size: 12px; cursor: pointer; font-weight: bold; z-index: 100; display: flex; align-items: center; justify-content: center;">
        X
    </button>


    @if (Node.GateType == "START" && !Node.IsNegatedVersion)
    {
        <button @onclick="changeValue"
                @onclick:stopPropagation="true"
                class="btn btn-sm btn-dark"
                style="width: 100%; margin-top: 10px; font-weight: bold; font-size: 0.75rem;">
            Zmenit stav
        </button>
    }

    @if (!Node.IsNegatedVersion && Node.Partner != null && Node.GateType.Contains("NEG"))
    {
        <div style="position: absolute; 
                left: 80px;           
                width: 80px;          
                top: 50%; 
                transform: translateY(-50%); 
                display: flex; 
                flex-direction: column; 
                align-items: center; 
                justify-content: center;
                pointer-events: none;
                z-index: 5;">
        
            <span style="font-size: 8px; color: #dc3545; font-weight: bold; margin-bottom: -2px; letter-spacing: 1px;">
                DE MORGAN
            </span>
            <span style="font-size: 20px; color: #adb5bd; line-height: 1;">➔</span>
        </div>
    }
    
</div>

    
@code {
    [Parameter] public GateNode Node { get; set; } = null!;
    [CascadingParameter] public BlazorDiagram Diagram { get; set; } = null!;

    private void changeValue()
    {
        if (Node.GateType == "START")
        {
            Node.Status = (Node.Status == NodeState.True) ? NodeState.False : NodeState.True;
            Node.Refresh();
        }
    }

    private void Delete() => Diagram.Nodes.Remove(Node);
}