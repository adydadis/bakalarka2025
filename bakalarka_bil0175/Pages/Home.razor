@page "/"
@using Blazor.Diagrams
@using Blazor.Diagrams.Core.Models
@using Blazor.Diagrams.Core.Geometry
@using Blazor.Diagrams.Options
@using Blazor.Diagrams.Core.Routers
@using Blazor.Diagrams.Core.PathGenerators
@using Blazor.Diagrams.Core.Anchors
@using Blazor.Diagrams.Components
@using bakalarka_bil0175


@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveWebAssemblyRenderMode(prerender: false))


<div style="margin-bottom: 10px;">
    <button class="btn btn-outline-primary" @onclick='() => AddStartNode()'>START</button>
    <button class="btn btn-outline-primary" @onclick='() => addGate("AND")'>∧ (AND)</button>
    <button class="btn btn-outline-primary" @onclick='() => addGate("OR")'>∨ (OR)</button>

    <button class="btn btn-outline-primary" @onclick='() => addGate("NEG_AND")'>¬ ∧ (NEG AND)</button>
    <button class="btn btn-outline-primary" @onclick='() => addGate("NEG_OR")'>¬ ∨ (NEG OR)</button>

    <button class="btn btn-outline-primary" @onclick='() => addGate("NEG")'>¬ (NEG)</button>
    <button @onclick="Calculate"
            style="background-color: #356ddc; 
               color: white; 
               border: 1px solid #1d28a7; 
               padding: 6px 12px; 
               border-radius: 4px; 
               font-weight: bold; 
               margin-left: 10px; 
               cursor: pointer;" >VYPOCITAT</button>
    <button @onclick="ClearAll"
            style="background-color: #dc3545; 
               color: white; 
               border: 1px solid #a71d2a; 
               padding: 6px 12px; 
               border-radius: 4px; 
               font-weight: bold; 
               margin-left: 10px; 
               cursor: pointer;">
        VYMAZAT VSE
    </button>
</div>

<div class="diagram-container" style="width: 100%; height: 600px; border: 1px solid black;">
    @if (Diagram != null)
    {
        <CascadingValue Value="Diagram" IsFixed="true">
            <DiagramCanvas></DiagramCanvas>
        </CascadingValue>
    }
</div>

@code {
    public BlazorDiagram Diagram { get; set; } = null!;
    private Circuit Evaluator = new();

    private void AddStartNode()
    {
        var count = Diagram.Nodes.OfType<GateNode>()
            .Count(n => n.GateType == "START" && !n.IsNegatedVersion);
    
        var newNode = new GateNode("START", new Point(100, 100), false, count + 1);
        Diagram.Nodes.Add(newNode);
    }
    
    protected override void OnInitialized()
    {
        var options = new BlazorDiagramOptions
        {
            AllowMultiSelection = true,
            Zoom = { Enabled = false },
            Links =
            {
                DefaultRouter = new NormalRouter(),
                DefaultPathGenerator = new SmoothPathGenerator()
            }
        };

        Diagram = new BlazorDiagram(options);
        Diagram.RegisterComponent<GateNode, GateWidget>();

        
        var start1 = new GateNode("START", new Point(50, 50), false, 1);
        
        start1.AddPort(PortAlignment.Right);
        Diagram.Nodes.Add(start1);

        var start2 = new GateNode("START", new Point(50, 250), false, 2);
        start2.AddPort(PortAlignment.Right);
        Diagram.Nodes.Add(start2);
        
        
        var start3 = new GateNode("START", new Point(50, 450), false, 3);
        start3.AddPort(PortAlignment.Right);
        Diagram.Nodes.Add(start3);

        var and = new GateNode("AND", new Point(350, 350));
        and.AddPort(PortAlignment.Left);  
        and.AddPort(PortAlignment.Left);  
        and.AddPort(PortAlignment.Right); 
        Diagram.Nodes.Add(and);

        var negAnd = new GateNode("NEG_AND", new Point(350, 150));
        negAnd.AddPort(PortAlignment.Left);  
        negAnd.AddPort(PortAlignment.Left);  
        negAnd.AddPort(PortAlignment.Right); 
        Diagram.Nodes.Add(negAnd);
    
        Diagram.Links.Add(new GateLink(start1.Ports[0], and.Ports[0], false));
        Diagram.Links.Add(new GateLink(start2.Ports[0], and.Ports[1], false));
        
        Diagram.Links.Add(new GateLink(and.Ports[2], negAnd.Ports[0], false));
        Diagram.Links.Add(new GateLink(start3.Ports[0], negAnd.Ports[1], false));
    }

    private void addGate(string type)
    {
        var newGate = new GateNode(type, new Point(50, 50), false);

        
        if (type == "START") newGate.AddPort(PortAlignment.Right);
        else if (type.Contains("AND") || type.Contains("OR"))
        {
            newGate.AddPort(PortAlignment.Left);
            newGate.AddPort(PortAlignment.Left);
            newGate.AddPort(PortAlignment.Right);
        }
        else { newGate.AddPort(PortAlignment.Left); newGate.AddPort(PortAlignment.Right); }

        Diagram.Nodes.Add(newGate);
    }
    
    private async Task Calculate()
    {
        Diagram.Batch(() =>
        {
            Evaluator.Evaluate(Diagram);
        });

        StateHasChanged();

        await Task.Delay(150);

        foreach (var node in Diagram.Nodes)
        {
            node.Refresh(); 
            foreach (var port in node.Ports)
            {
                port.Refresh(); 
            }
        }

        foreach (var link in Diagram.Links)
        {
            link.Refresh(); 
        }

        
        Diagram.Refresh();
    }
    
    private void ClearAll()
    {
        Diagram.Batch(() =>
        {
            Diagram.Nodes.Clear();
        
            Diagram.Links.Clear();
        });

        Diagram.Refresh();
        StateHasChanged();
    }
}